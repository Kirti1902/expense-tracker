# Get this from @BotFather on Telegram after running /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram numeric user ID (get it from @userinfobot on Telegram)
# Only messages from this ID will be processed by the bot — keeps it private to you.
TELEGRAM_OWNER_ID=your_telegram_user_id_here

# Port for the web dashboard / API
PORT=3000

# Currency symbol shown in the dashboard (e.g. $, ₹, €, £)
CURRENCY_SYMBOL=₹
